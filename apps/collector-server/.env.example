# collector-server 环境变量示例
#
# 复制为 .env 并按需修改：  cp .env.example .env
#
# ⚠️ 加载方式：当前代码直接读取 process.env（未集成 dotenv）。
#   - 开发：shell 注入，如  COLLECTOR_TOKEN=xxx pnpm dev
#   - 生产：node --env-file=.env dist/main.js

# HTTP + WebSocket 监听端口（默认 21527）。
# 改了必须同步修改 apps/subtitle-collector/config.js 的 SERVER_URL 与 PING_URL。
COLLECTOR_PORT=21527

# SQLite 数据库路径（相对 collector-server 工作目录，默认 ./bilibili-collector.db）。
COLLECTOR_DB_PATH=./bilibili-collector.db

# WebSocket 握手鉴权 token —— 生产部署【必须】改成随机串！
# 必须与 apps/subtitle-collector/config.js 的 TOKEN 完全一致，否则扩展连不上。
# 生成随机串：node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
COLLECTOR_TOKEN=change-me-collector-token

# ──────────────────────────────────────────────────────────
# 说明：
# - 服务端固定监听 127.0.0.1（防 DNS rebinding），没有 bind host 配置项。
# - B 站登录态不在此配置：由扩展通过浏览器 cookie + host_permissions 获取，
#   collector-server 不存储任何 B 站凭据。
# - collector-web 不读环境变量（API 同源走 server 静态托管）。
