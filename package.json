{
  "name": "bilibili-extensions",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo run test",
    "test:ext": "turbo run build --filter=@bilibili-ext/subtitle-collector && node scripts/verify-collector.mjs",
    "cli": "pnpm -C apps/collector-server exec tsx src/cli/main.ts",
    "collect-uppers": "pnpm -C apps/collector-server exec tsx ../../scripts/collect-uppers.mts"
  },
  "devDependencies": {
    "turbo": "^2",
    "puppeteer": "^23.0.0",
    "ws": "^8.18.0"
  },
  "packageManager": "pnpm@9.15.4"
}
